#!/usr/bin/env sh

# Block merge commits so history stays rebase-only.
if [ -f "$(git rev-parse --git-dir)/MERGE_HEAD" ]; then
  echo "Merge commits are not allowed. Please use rebase instead."
  exit 1
fi

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)
PREEXISTING_MODIFIED_FILES=$(git diff --name-only)

if [ -z "$STAGED_FILES" ]; then
  echo "No staged files to check."
  exit 0
fi

BIOME_FILES=""
TAILWIND_FILES=""

for file in $STAGED_FILES; do
  case "$file" in
    *.js|*.jsx|*.ts|*.tsx|*.json|*.jsonc|*.css|*.html|*.svelte)
      if [ -f "$file" ]; then
        BIOME_FILES="$BIOME_FILES $file"
      fi
      ;;
  esac

  case "$file" in
    apps/atlas-app/*|package.json|bun.lock)
      if [ -f "$file" ]; then
        TAILWIND_FILES="$TAILWIND_FILES $file"
      fi
      ;;
  esac
done

if [ -z "$BIOME_FILES" ] && [ -z "$TAILWIND_FILES" ]; then
  echo "No staged files supported by pre-commit checks."
  exit 0
fi

if [ -n "$TAILWIND_FILES" ]; then
  echo "Running Tailwind upgrade..."

  set +e
  TAILWIND_OUTPUT=$(bun x @tailwindcss/upgrade --force 2>&1)
  TAILWIND_STATUS=$?
  set -e

  if [ $TAILWIND_STATUS -ne 0 ]; then
    echo "$TAILWIND_OUTPUT"
    exit $TAILWIND_STATUS
  fi
fi

if [ -n "$BIOME_FILES" ]; then
  echo "Running Biome on staged files..."

  set +e
  BIOME_OUTPUT=$(bun x biome check --write $BIOME_FILES 2>&1)
  BIOME_STATUS=$?
  set -e

  if [ $BIOME_STATUS -ne 0 ]; then
    if echo "$BIOME_OUTPUT" | grep -q "No files were processed in the specified paths."; then
      echo "Biome had no matching files to process."
    else
      echo "$BIOME_OUTPUT"
      exit $BIOME_STATUS
    fi
  fi
else
  echo "No staged files supported by Biome."
fi

MODIFIED_FILES=$(git diff --name-only)
NEWLY_MODIFIED_FILES=""
TOOL_MODIFIED_STAGED=""

for file in $MODIFIED_FILES; do
  if ! echo "$PREEXISTING_MODIFIED_FILES" | grep -qFx "$file"; then
    NEWLY_MODIFIED_FILES="$NEWLY_MODIFIED_FILES $file"
  fi
done

for file in $STAGED_FILES $NEWLY_MODIFIED_FILES; do
  if [ -n "$file" ] && echo "$MODIFIED_FILES" | grep -qFx "$file"; then
    TOOL_MODIFIED_STAGED="$TOOL_MODIFIED_STAGED $file"
  fi
done

if [ -n "$TOOL_MODIFIED_STAGED" ]; then
  echo
  echo "Pre-commit tools modified files:"
  echo "$TOOL_MODIFIED_STAGED" | tr ' ' '\n' | grep -v '^$' | sort -u | sed 's/^/  - /'
  echo
  echo "Review the changes and re-stage them before committing."
  exit 1
fi

echo "Pre-commit checks passed."
