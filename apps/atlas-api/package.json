{
  "name": "atlas-api",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --env preview --persist-to .local/d1/dev",
    "build": "mkdir -p dist && wrangler deploy --dry-run --env production --outdir dist --minify",
    "build:preview": "mkdir -p dist && wrangler deploy --dry-run --env preview --outdir dist --minify",
    "build:production": "mkdir -p dist && wrangler deploy --dry-run --env production --outdir dist --minify",
    "db:generate": "bun run --cwd ../.. db:generate",
    "db:dump:preview": "bun run --cwd ../.. db:dump:preview",
    "db:dump:production": "bun run --cwd ../.. db:dump:production",
    "db:reset:local": "bun run --cwd ../.. db:reset:local",
    "db:migration:run:local": "bun run --cwd ../.. db:migration:run:local",
    "db:migration:run:preview": "bun run --cwd ../.. db:migration:run:preview",
    "db:migration:run:production": "bun run --cwd ../.. db:migration:run:production",
    "db:import:local": "bun run --cwd ../.. db:import:local",
    "db:rebuild-fts:local": "bun run --cwd ../.. db:rebuild-fts:local",
    "db:mirror:preview:to:local": "bun run --cwd ../.. db:mirror:preview:to:local",
    "db:mirror:production:to:local": "bun run --cwd ../.. db:mirror:production:to:local",
    "deploy": "wrangler deploy --env production --minify",
    "deploy:preview": "wrangler deploy --env preview --minify",
    "deploy:production": "wrangler deploy --env production --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "check": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "bun-types": "^1.3.0",
    "drizzle-kit": "^0.31.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.44.0"
  },
  "dependencies": {
    "@repo/db": "workspace:*",
    "drizzle-orm": "^1.0.0-rc.3",
    "hono": "^4.10.1"
  }
}
