{
  "name": "atlas-app",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && wrangler types --env-interface Env",
    "build:preview": "vite build && wrangler types --env-interface Env",
    "build:production": "vite build && wrangler types --env-interface Env",
    "deploy": "bun run build:production && wrangler deploy --env production",
    "deploy:preview": "bun run build:preview && wrangler deploy --env preview",
    "deploy:production": "bun run build:production && wrangler deploy --env production",
    "preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "cf-typegen": "wrangler types --env-interface Env",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage"
  },
  "dependencies": {
    "@iconify-json/proicons": "^1.2.19",
    "@iconify/svelte": "^5.2.1",
    "@repo/db": "workspace:*",
    "better-auth": "~1.4.21",
    "bits-ui": "^2.18.1"
  },
  "devDependencies": {
    "@better-auth/cli": "~1.4.21",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.57.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24",
    "@vitest/browser-playwright": "^4.1.3",
    "drizzle-kit": "^0.31.10",
    "playwright": "^1.60.0",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.7",
    "vitest": "^4.1.3",
    "vitest-browser-svelte": "^2.1.0",
    "wrangler": "^4.81.0"
  }
}
