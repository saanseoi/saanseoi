{
  "name": "harbour-cli",
  "type": "module",
  "scripts": {
    "check": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "prep-hkgov-als": "bun ./src/cli.ts prep-hkgov-als",
    "prep-hkgov-als:preview": "bun ./src/cli.ts prep-hkgov-als:preview",
    "prep-hkgov-als:production": "bun ./src/cli.ts prep-hkgov-als:production",
    "upload": "bun ./src/cli.ts upload",
    "upload:local": "bun ./src/cli.ts upload --target local",
    "upload:cf:preview": "bun ./src/cli.ts upload --target cf-preview",
    "upload:cf:production": "bun ./src/cli.ts upload --target cf-production"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "bun-types": "^1.3.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "@repo/core": "workspace:*",
    "hyparquet-writer": "^0.15.7"
  }
}
