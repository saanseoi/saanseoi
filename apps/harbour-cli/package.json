{
  "name": "harbour-cli",
  "type": "module",
  "scripts": {
    "check": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "prep-hkgov-als": "bun ./src/cli.ts prep-hkgov-als",
    "prep-hkgov-als:preview": "bun ./src/cli.ts prep-hkgov-als --target cf-preview",
    "prep-hkgov-als:production": "bun ./src/cli.ts prep-hkgov-als --target cf-production",
    "reports:ingestion": "bun ./src/cli.ts reports:ingestion",
    "reports:ingestion:local": "bun ./src/cli.ts reports:ingestion --target local",
    "reports:ingestion:cf:preview": "bun ./src/cli.ts reports:ingestion --target cf-preview",
    "reports:ingestion:cf:production": "bun ./src/cli.ts reports:ingestion --target cf-production",
    "reports:stats": "bun ./src/cli.ts reports:stats",
    "reports:stats:local": "bun ./src/cli.ts reports:stats --target local",
    "reports:stats:cf:preview": "bun ./src/cli.ts reports:stats --target cf-preview",
    "reports:stats:cf:production": "bun ./src/cli.ts reports:stats --target cf-production",
    "reports:releases": "bun ./src/cli.ts reports:releases",
    "reports:releases:local": "bun ./src/cli.ts reports:releases --target local",
    "reports:releases:cf:preview": "bun ./src/cli.ts reports:releases --target cf-preview",
    "reports:releases:cf:production": "bun ./src/cli.ts reports:releases --target cf-production",
    "upload": "bun ./src/cli.ts upload",
    "upload:local": "bun ./src/cli.ts upload --target local",
    "upload:cf:preview": "bun ./src/cli.ts upload --target cf-preview",
    "upload:cf:production": "bun ./src/cli.ts upload --target cf-production",
    "upload:finalize": "bun ./src/cli.ts upload:finalize",
    "upload:finalize:local": "bun ./src/cli.ts upload:finalize --target local",
    "upload:finalize:cf:preview": "bun ./src/cli.ts upload:finalize --target cf-preview",
    "upload:finalize:cf:production": "bun ./src/cli.ts upload:finalize --target cf-production"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "bun-types": "^1.3.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "@repo/core": "workspace:*",
    "hyparquet-writer": "^0.16.1"
  }
}
