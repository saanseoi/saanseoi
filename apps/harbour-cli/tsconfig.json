{
  "extends": "../../libs/config-typescript/tsconfig.json",
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "allowJs": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,
    "rootDir": "../../",
    "outDir": "dist",
    "types": ["bun-types"],
    "paths": {
      "@/*": ["./src/*"],
      "@repo/harbour-core": ["../../libs/harbour-core/src/index.ts"],
      "@repo/harbour-core/upload-local": [
        "../../libs/harbour-core/src/lib/services/upload-local.ts"
      ],
      "drizzle-orm": ["../../libs/db/node_modules/drizzle-orm"],
      "drizzle-orm/*": ["../../libs/db/node_modules/drizzle-orm/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts"],
  "exclude": ["node_modules", "dist"]
}
