{
  "name": "harbour-api",
  "type": "module",
  "scripts": {
    "dev": "bash ../../scripts/dev-local-stack.sh",
    "build": "mkdir -p dist && wrangler deploy --dry-run --env production --outdir dist --minify",
    "build:preview": "mkdir -p dist && wrangler deploy --dry-run --env preview --outdir dist --minify",
    "build:production": "mkdir -p dist && wrangler deploy --dry-run --env production --outdir dist --minify",
    "deploy": "wrangler deploy --env production --minify",
    "deploy:preview": "wrangler deploy --env preview --minify",
    "deploy:production": "wrangler deploy --env production --minify",
    "check": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "bun-types": "^1.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "wrangler": "^4.100.0"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.4.0",
    "@aws-sdk/client-s3": "^3.1068.0",
    "@aws-sdk/s3-request-presigner": "^3.1068.0",
    "@repo/core": "workspace:*",
    "@repo/db": "workspace:*",
    "@scalar/hono-api-reference": "^0.11.3",
    "@scalar/openapi-to-markdown": "^0.5.25",
    "hono": "^4.10.1",
    "zod": "^4.4.3"
  }
}
