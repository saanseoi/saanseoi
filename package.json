{
  "name": "saanseoi",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "packageManager": "bun@1.3.0",
  "bin": {
    "saanseoi": "./bin/saanseoi"
  },
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "prepare": "husky",
    "dev": "turbo run dev --filter=harbour-api --filter=atlas-api --filter=atlas-app",
    "update": "bun update --interactive --recursive",
    "outdated": "bun outdated --recursive",
    "upload": "bun --cwd ./apps/harbour-cli ./src/cli.ts upload",
    "upload:cf:preview": "bun --cwd ./apps/harbour-cli ./src/cli.ts upload --target cf-preview",
    "upload:cf:production": "bun --cwd ./apps/harbour-cli ./src/cli.ts upload --target cf-production",
    "fish:install-completions": "bash ./scripts/install-fish-completions.sh",
    "db:chart": "bun run --filter @repo/db db:chart",
    "db:studio": "bun run --filter @repo/db db:studio",
    "db:studio:preview": "bun run --filter @repo/db db:studio:preview",
    "db:studio:production": "bun run --filter @repo/db db:studio:production",
    "db:studio:meta": "bun run --filter @repo/db db:studio:meta",
    "db:studio:current": "bun run --filter @repo/db db:studio:current",
    "db:studio:history": "bun run --filter @repo/db db:studio:history",
    "db:studio:history:2025": "bun run --filter @repo/db db:studio:history:2025",
    "db:studio:source": "bun run --filter @repo/db db:studio:source",
    "db:studio:source:2025": "bun run --filter @repo/db db:studio:source:2025",
    "db:studio:preview:meta": "bun run --filter @repo/db db:studio:preview:meta",
    "db:studio:preview:current": "bun run --filter @repo/db db:studio:preview:current",
    "db:studio:preview:history": "bun run --filter @repo/db db:studio:preview:history",
    "db:studio:preview:source": "bun run --filter @repo/db db:studio:preview:source",
    "db:studio:production:meta": "bun run --filter @repo/db db:studio:production:meta",
    "db:studio:production:current": "bun run --filter @repo/db db:studio:production:current",
    "db:studio:production:history": "bun run --filter @repo/db db:studio:production:history",
    "db:studio:production:source": "bun run --filter @repo/db db:studio:production:source",
    "db:dump:preview": "bun run --filter @repo/db db:dump:preview",
    "db:dump:production": "bun run --filter @repo/db db:dump:production",
    "db:reset:local": "bun run --filter @repo/db db:reset:local",
    "db:reset:preview": "bun run --filter @repo/db db:reset:preview",
    "db:migration:generate": "bun run --filter @repo/db db:migration:generate",
    "db:migration:run:local": "bun run --filter @repo/db db:migration:run:local",
    "db:migration:run:local:meta": "bun run --filter @repo/db db:migration:run:local:meta",
    "db:migration:run:preview": "bun run --filter @repo/db db:migration:run:preview",
    "db:migration:run:cf:preview": "bun run --filter @repo/db db:migration:run:preview",
    "db:migration:run:production": "bun run --filter @repo/db db:migration:run:production",
    "db:migration:run:cf:production": "bun run --filter @repo/db db:migration:run:production",
    "db:import:local": "bun run --filter @repo/db db:import:local",
    "db:rebuild-fts:local": "bun run --filter @repo/db db:rebuild-fts:local",
    "db:mirror:preview:to:local": "bun run --filter @repo/db db:mirror:preview:to:local",
    "db:mirror:production:to:local": "bun run --filter @repo/db db:mirror:production:to:local",
    "db:seed:meta": "bun run --filter @repo/db db:seed:meta",
    "db:seed:preview:meta": "bun run --filter @repo/db db:seed:preview:meta",
    "db:seed:cf:preview:meta": "bun run --filter @repo/db db:seed:preview:meta",
    "db:seed:production:meta": "bun run --filter @repo/db db:seed:production:meta",
    "db:seed:cf:production:meta": "bun run --filter @repo/db db:seed:production:meta",
    "db:list": "bun x wrangler d1 list",
    "d1:recreate": "bun ./scripts/recreate-d1-binding.ts",
    "d1:converge": "bun ./scripts/converge-d1-placement.ts",
    "d1:probe": "bash ./scripts/run-d1-placement-probes.sh all 20",
    "d1:probe:preview": "bash ./scripts/run-d1-placement-probes.sh preview 20",
    "d1:probe:production": "bash ./scripts/run-d1-placement-probes.sh production 20",
    "test": "turbo run test",
    "test:run": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:coverage": "turbo run test:coverage",
    "preview": "turbo run preview",
    "check": "turbo run check",
    "format": "biome format --write .",
    "deploy": "turbo run deploy --filter=atlas-api --filter=atlas-app --filter=harbour-api --filter=harbour-workers",
    "deploy:preview": "turbo run deploy:preview --filter=atlas-api --filter=atlas-app --filter=harbour-api --filter=harbour-workers",
    "deploy:production": "turbo run deploy:production --filter=atlas-api --filter=atlas-app --filter=harbour-api --filter=harbour-workers",
    "lint": "turbo run lint",
    "lint:branch": "bunx branch-name-lint .husky/branch-name-lint.json",
    "machine-translate": "turbo run machine-translate",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo run build && changeset publish",
    "cf-typegen": "bun run --workspaces --if-present cf-typegen"
  },
  "dependencies": {
    "@inlang/paraglide-js": "^2.20.1",
    "bits-ui": "^2.18.1",
    "bun-types": "^1.3.14",
    "drizzle-orm": "^1.0.0-rc.4-5d5b77c",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@iconify/svelte": "^5.2.2",
    "@tailwindcss/upgrade": "^4.3.1",
    "@types/bun": "latest",
    "branch-name-lint": "^3.0.1",
    "drizzle-kit": "^1.0.0-rc.4-ca0f029",
    "husky": "^9.1.7",
    "tailwindcss-animate": "^1.0.7",
    "turbo": "^2.9.18",
    "wrangler": "^4.104.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/saanseoi/saanseoi.git"
  },
  "author": "tijptjik <m@type.hk>",
  "license": "MIT",
  "homepage": "https://saanseoi.hk",
  "bugs": {
    "url": "https://github.com/saanseoi/saanseoi/issues"
  }
}
